{{ app_domain }} {
    root * {{ app_root }}/public
    file_server

    php_fastcgi unix//var/run/php/php{{ php_version }}-fpm.sock

    log {
        output file /var/log/caddy/{{ app_name }}_access.log
    }

    handle_errors {
        @404 {
            expression {err.status_code} == 404
        }
        rewrite @404 /index.php
    }
}
