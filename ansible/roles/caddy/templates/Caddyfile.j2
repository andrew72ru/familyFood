{{ app_domain }} {
    # If app_root doesn't end in /current, we are likely in provisioning
    # Deployment always uses /current
    {% set project_dir = app_root if app_root.endswith('/current') else app_root ~ '/current' %}

    # Handle Symfony API and assets
    handle /api* {
        root * {{ project_dir }}/public
        php_fastcgi unix//var/run/php/php{{ '8.4' if (ansible_distribution == 'Ubuntu' and ansible_distribution_release == 'plucky') else php_version }}-fpm.sock
    }

    handle /images* {
        root * {{ project_dir }}/public
        file_server
    }

    handle /bundles* {
        root * {{ project_dir }}/public
        file_server
    }

    # Handle React frontend
    handle {
        root * {{ project_dir }}/frontend/build
        try_files {path} /index.html
        file_server
    }

    log {
        output file /var/log/caddy/{{ app_name }}_access.log
    }
}
