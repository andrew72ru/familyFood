https://localhost:443 {
    tls internal
    # Vulcain module
    vulcain

    # Handle Symfony API
    handle /api* {
        reverse_proxy host.docker.internal:8000 {
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}
        }
    }

    handle /images* {
        reverse_proxy host.docker.internal:8000
    }

    handle /bundles* {
        reverse_proxy host.docker.internal:8000
    }

    # Handle React frontend (proxy to npm start dev server)
    handle {
        reverse_proxy host.docker.internal:3000
    }

    log {
        output stdout
    }
}
